services:
  chrony:
    image: provider-box/chrony:0.1.0
    restart: unless-stopped
    # Host networking so NTP serves on the host's UDP 123; SYS_TIME is the one
    # capability chronyd needs to discipline the host clock.
    network_mode: host
    cap_drop:
      - ALL
    cap_add:
      - SYS_TIME
    volumes:
      - /opt/provider-box/runtime/chrony/chrony.conf:/etc/chrony/chrony.conf:ro
      - /opt/provider-box/chrony:/var/lib/chrony
