services:
  rsyslog:
    image: labprovider/rsyslog:0.1.0
    restart: unless-stopped
    # Host networking so syslog serves on the host's SYSLOG_PORT. The log dir
    # is mounted at the same path as on the host because the rendered config's
    # dynafile template contains the host path.
    network_mode: host
    volumes:
      - /opt/labprovider/runtime/rsyslog/rsyslog.conf:/etc/rsyslog.conf:ro
      - /opt/labprovider/syslog/logs:/opt/labprovider/syslog/logs
